{
  "version": 2,
  "name": "oasis-guest-house-inventory-frontend",
  "builds": [
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "https://oasis-guest-house-inventory-production.up.railway.app/api/$1" },
    { "src": "/uploads/(.*)", "dest": "https://oasis-guest-house-inventory-production.up.railway.app/uploads/$1" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
