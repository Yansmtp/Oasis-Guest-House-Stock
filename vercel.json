{
  "version": 2,
  "name": "oasis-guest-house-inventory-frontend",
  "builds": [
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "https://oasis-guest-house-stock-ok.up.railway.app/api/$1" },
    { "src": "/uploads/(.*)", "dest": "https://oasis-guest-house-stock-ok.up.railway.app/uploads/$1" },
    { "src": "/(.*)\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff2?)", "dest": "/frontend/$1.$2" },
    { "src": "/(.*)", "dest": "/frontend/index.html" }
  ]
}
